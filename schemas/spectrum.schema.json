{
  "$defs": {
    "Material": {
      "description": "Classification of the material whose spectrum was measured.",
      "properties": {
        "name": {
          "description": "Material name (e.g. Olivine, Quartz, Oak leaf).",
          "title": "Name",
          "type": "string"
        },
        "category": {
          "$ref": "#/$defs/MaterialCategory",
          "description": "Top-level material category."
        },
        "subcategory": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Source-specific subcategory (e.g. ECOSTRESS SubClass, mineral group).",
          "title": "Subcategory"
        },
        "formula": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Chemical formula where applicable.",
          "title": "Formula"
        },
        "keywords": {
          "description": "Searchable terms for discovery.",
          "items": {
            "type": "string"
          },
          "title": "Keywords",
          "type": "array"
        }
      },
      "required": [
        "name",
        "category"
      ],
      "title": "Material",
      "type": "object"
    },
    "MaterialCategory": {
      "description": "Controlled vocabulary for material classification.",
      "enum": [
        "mineral",
        "rock",
        "soil",
        "vegetation",
        "npv",
        "water",
        "snow_ice",
        "man_made",
        "meteorite",
        "lunar",
        "organic_compound",
        "mixture",
        "other"
      ],
      "title": "MaterialCategory",
      "type": "string"
    },
    "Measurement": {
      "description": "Instrument and conditions under which the spectrum was acquired.",
      "properties": {
        "instrument": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Instrument name and model.",
          "title": "Instrument"
        },
        "instrument_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Category of instrument (e.g. laboratory_spectrometer, ftir).",
          "title": "Instrument Type"
        },
        "laboratory": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Laboratory or facility where the measurement was performed.",
          "title": "Laboratory"
        },
        "technique": {
          "$ref": "#/$defs/MeasurementTechnique",
          "description": "Measurement technique (reflectance, emissivity, absorbance, transmittance)."
        },
        "geometry": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Measurement geometry (e.g. biconical, hemispherical).",
          "title": "Geometry"
        },
        "date": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Date the measurement was acquired (ISO 8601).",
          "title": "Date"
        }
      },
      "required": [
        "technique"
      ],
      "title": "Measurement",
      "type": "object"
    },
    "MeasurementTechnique": {
      "description": "Type of spectral measurement.",
      "enum": [
        "reflectance",
        "emissivity",
        "absorbance",
        "transmittance"
      ],
      "title": "MeasurementTechnique",
      "type": "string"
    },
    "Quality": {
      "description": "Data quality indicators for a spectrum.",
      "properties": {
        "has_bad_bands": {
          "default": false,
          "description": "Whether any bad or invalid bands are present.",
          "title": "Has Bad Bands",
          "type": "boolean"
        },
        "bad_band_count": {
          "default": 0,
          "description": "Number of invalid data points.",
          "minimum": 0,
          "title": "Bad Band Count",
          "type": "integer"
        },
        "coverage_fraction": {
          "default": 1.0,
          "description": "Fraction of data points that are valid (0.0\u20131.0).",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Coverage Fraction",
          "type": "number"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Additional quality notes.",
          "title": "Notes"
        }
      },
      "title": "Quality",
      "type": "object"
    },
    "Sample": {
      "description": "Information about the physical sample that was measured.",
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Sample identifier from the source.",
          "title": "Id"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Free-text sample description.",
          "title": "Description"
        },
        "particle_size": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Particle size or size range as reported.",
          "title": "Particle Size"
        },
        "origin": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Geographic or geological origin of the sample.",
          "title": "Origin"
        },
        "owner": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Institution or individual owning the sample.",
          "title": "Owner"
        },
        "collection_date": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Date the sample was collected (ISO 8601).",
          "title": "Collection Date"
        },
        "preparation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Description of sample preparation procedures.",
          "title": "Preparation"
        }
      },
      "title": "Sample",
      "type": "object"
    },
    "Source": {
      "description": "Provenance information linking a spectrum to its origin library.",
      "properties": {
        "library": {
          "$ref": "#/$defs/SourceLibrary",
          "description": "Source spectral library identifier."
        },
        "library_version": {
          "description": "Version of the source library.",
          "title": "Library Version",
          "type": "string"
        },
        "original_id": {
          "description": "Identifier used in the source library.",
          "title": "Original Id",
          "type": "string"
        },
        "filename": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Original filename in the source archive.",
          "title": "Filename"
        },
        "url": {
          "description": "DOI or URL for the source library.",
          "title": "Url",
          "type": "string"
        },
        "license": {
          "description": "License governing the source data.",
          "title": "License",
          "type": "string"
        },
        "citation": {
          "description": "Recommended citation string.",
          "title": "Citation",
          "type": "string"
        }
      },
      "required": [
        "library",
        "library_version",
        "original_id",
        "url",
        "license",
        "citation"
      ],
      "title": "Source",
      "type": "object"
    },
    "SourceLibrary": {
      "description": "Supported source spectral libraries.",
      "enum": [
        "usgs_splib07",
        "ecostress",
        "relab",
        "asu_tes",
        "bishop"
      ],
      "title": "SourceLibrary",
      "type": "string"
    },
    "SpectralData": {
      "description": "Spectral measurement data and associated axis information.",
      "properties": {
        "type": {
          "$ref": "#/$defs/MeasurementTechnique",
          "description": "Type of spectral values (reflectance, emissivity, absorbance, transmittance)."
        },
        "wavelength_unit": {
          "$ref": "#/$defs/WavelengthUnit",
          "description": "Unit of the wavelength axis (um, nm, or cm-1)."
        },
        "wavelength_min": {
          "description": "Minimum value on the wavelength axis.",
          "title": "Wavelength Min",
          "type": "number"
        },
        "wavelength_max": {
          "description": "Maximum value on the wavelength axis.",
          "title": "Wavelength Max",
          "type": "number"
        },
        "num_points": {
          "description": "Number of spectral data points.",
          "minimum": 1,
          "title": "Num Points",
          "type": "integer"
        },
        "wavelengths": {
          "description": "Wavelength (or wavenumber) axis values.",
          "items": {
            "type": "number"
          },
          "title": "Wavelengths",
          "type": "array"
        },
        "values": {
          "description": "Spectral measurement values.",
          "items": {
            "type": "number"
          },
          "title": "Values",
          "type": "array"
        },
        "bandpass": {
          "anyOf": [
            {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Bandpass (FWHM) at each wavelength position, if available.",
          "title": "Bandpass"
        }
      },
      "required": [
        "type",
        "wavelength_unit",
        "wavelength_min",
        "wavelength_max",
        "num_points",
        "wavelengths",
        "values"
      ],
      "title": "SpectralData",
      "type": "object"
    },
    "WavelengthUnit": {
      "description": "Wavelength or wavenumber units.",
      "enum": [
        "um",
        "nm",
        "cm-1"
      ],
      "title": "WavelengthUnit",
      "type": "string"
    }
  },
  "description": "A single spectrum with full spectral data \u2014 used in library chunk files.",
  "properties": {
    "id": {
      "description": "Globally unique identifier ({source_library}:{original_id}).",
      "title": "Id",
      "type": "string"
    },
    "name": {
      "description": "Human-readable display name.",
      "title": "Name",
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/Source",
      "description": "Provenance information."
    },
    "material": {
      "$ref": "#/$defs/Material",
      "description": "Material classification."
    },
    "sample": {
      "$ref": "#/$defs/Sample",
      "description": "Sample information."
    },
    "measurement": {
      "$ref": "#/$defs/Measurement",
      "description": "Measurement conditions."
    },
    "spectral_data": {
      "$ref": "#/$defs/SpectralData",
      "description": "Spectral measurement data."
    },
    "additional_properties": {
      "additionalProperties": true,
      "description": "Source-specific metadata not captured by the standard fields.",
      "title": "Additional Properties",
      "type": "object"
    },
    "quality": {
      "$ref": "#/$defs/Quality",
      "description": "Data quality indicators."
    }
  },
  "required": [
    "id",
    "name",
    "source",
    "material",
    "sample",
    "measurement",
    "spectral_data"
  ],
  "title": "SpectrumRecord",
  "type": "object"
}
